# Copy this file to .env and fill in what you need for local dev.
# .env is gitignored - never commit real values. Only read by
# `python -m server.src.Server` and `python -m client.src.Client`; the
# Render deploy and the built static site set real env vars instead and
# never read this file.

# Optional: enables "Sign in with Google" and Google Drive backup/restore.
# Must be set for BOTH the server and the client to the same value.
# See README's "One-time environment setup" for how to create one.
PRIOTASK_GOOGLE_CLIENT_ID=

# Optional: where the client points its API calls. Defaults to
# http://localhost:5000, which is right if you're running the server
# locally too - only override if the server runs elsewhere.
PRIOTASK_API_BASE_URL=http://localhost:5000

# Optional: how many days a login session stays valid without activity.
# Defaults to 7.
PRIOTASK_SESSION_EXPIRY_DAYS=7

# Optional: set to "true" to auto-seed an admin/adminadmin demo account on
# server boot if the database is empty. Used on the deployed Render
# instance; usually left unset locally.
PRIOTASK_SEED_DEMO=
